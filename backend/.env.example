# Application
NODE_ENV=development
# Port HTTP Nest (préférez API_PORT si votre OS définit déjà PORT=3000)
API_PORT=3001
PORT=3001
API_PREFIX=api
SWAGGER_DOCS_PATH=docs
APP_URL=http://localhost:3000

# PostgreSQL (Prisma DATABASE_URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/patrimoine?schema=public"
# With backend/docker-compose.yml (port 5433):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/patrimoine?schema=public"

# JWT (scaffold — wire up in a later step)
JWT_SECRET=change-me-in-production

# SMTP (recommended quick setup without custom domain)
MAIL_FROM_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Resend (invitation emails)
RESEND_API_KEY=
# Use a verified sender/domain in Resend.
# For quick dev tests you can use onboarding@resend.dev.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cloudinary (upload flow scaffold)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Backblaze B2 (S3-compatible) for private documents
B2_ENDPOINT=
B2_REGION=us-west-004
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_PUBLIC_BASE_URL=
