# Application
NODE_ENV=development
# Port HTTP Nest (préférez API_PORT si votre OS définit déjà PORT=3000)
API_PORT=3001
PORT=3001
API_PREFIX=api
SWAGGER_DOCS_PATH=docs

# PostgreSQL (Prisma DATABASE_URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/patrimoine?schema=public"
# With backend/docker-compose.yml (port 5433):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/patrimoine?schema=public"

# JWT (scaffold — wire up in a later step)
JWT_SECRET=change-me-in-production

# Cloudinary (upload flow scaffold)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
