generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

/** Catégories spatiales chantier / patrimoine (MVP Zone). */
enum ZoneType {
  WALL
  ARCADE
  TALUS
  MUSEUM
  COLUMN
  PERIPHERAL_WALL
  ROOM
  SECTION
  OTHER
}

enum HeritageSensitivity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ElementType {
  WALL
  FLOOR
  ROOF
  JOINERY
  STRUCTURAL_MEMBER
  DECORATIVE_FEATURE
  INSTALLATION
  FOUNDATION
  OTHER
}

enum ObservationType {
  SITE_VISUAL
  MEASURE
  CONDITION_SURVEY
  MONITORING
  PRE_INTERVENTION
  POST_INTERVENTION
  MEETING_NOTE
  OTHER
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PathologyType {
  CRACKING
  MOISTURE
  SALT_ATTACK
  DETACHMENT
  BIOLOGICAL_GROWTH
  MATERIAL_LOSS
  DEFORMATION
  CORROSION
  COATING_FAILURE
  OTHER
}

enum DecisionType {
  CONSERVATION_APPROACH
  INTERVENTION_PRINCIPLE
  MATERIAL_CHOICE
  METHODOLOGY
  VALIDATION_PV
  REGULATORY
  OTHER
}

enum DecisionStatus {
  DRAFT
  PROPOSED
  APPROVED
  SUPERSEDED
  CANCELLED
}

enum InterventionType {
  CLEANING
  CONSOLIDATION
  REPAIR
  REPLACEMENT_PARTIAL
  PROTECTION
  RE_INTEGRATION
  PROVISIONAL
  SURVEY
  OTHER
}

enum InterventionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  VERIFIED
  CANCELLED
}

enum WeatherType {
  CLEAR
  CLOUDY
  RAIN
  WIND
  FOG
  OTHER
}

enum LabTestType {
  PETROGRAPHY
  SALT_CHLORIDE
  MOISTURE
  MECHANICAL
  PIGMENT_BINDER
  RADIOGRAPHY
  DATING
  OTHER
}

enum LabTestResult {
  POSITIVE
  NEGATIVE
  INCONCLUSIVE
  PENDING
  OTHER
}

enum RiskCategory {
  STRUCTURAL
  HERITAGE_VALUE
  HEALTH_SAFETY
  ENVIRONMENTAL
  SCHEDULE
  COST
  REPUTATIONAL
  OTHER
}

enum RiskProbability {
  RARE
  UNLIKELY
  POSSIBLE
  LIKELY
  ALMOST_CERTAIN
}

enum RiskImpact {
  NEGLIGIBLE
  MINOR
  MODERATE
  MAJOR
  CATASTROPHIC
}

enum RiskStatus {
  OPEN
  MITIGATING
  CLOSED
  ACCEPTED
}

enum MaterialType {
  STONE
  BRICK
  WOOD
  METAL
  GLASS
  CERAMIC
  MORTAR
  CONCRETE
  EARTH
  OTHER
}

enum ActorRole {
  OWNER
  ARCHITECT
  COMPANY
  LABORATORY
  ENGINEERING_OFFICE
  EXPERT
  ADMINISTRATION
  CONTRACTOR
  OTHER
}

/** Rôles plateforme (comptes utilisateurs). */
enum UserRole {
  ADMIN
  USER
  ACTEUR
}

enum AccountStatus {
  INVITED
  ACTIVE

  @@map("UserAccountStatus")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UploadScope {
  PROJECT
  ZONE
}

enum StorageType {
  CLOUDINARY
  B2
}

enum FileKind {
  PHOTO
  SCAN
  REPORT
  DRAWING
  MINUTES_PV
  CONTRACT
  LAB_REPORT
  CERTIFICATE
  CORRESPONDENCE
  OTHER
  CPS
  PLAN
  NOTE
  FICHE_TECHNIQUE
  PLANNING
}

/** Phase chantier pour médias zone (dossier Cloudinary `.../photos/{avant|pendant|apres}`). */
enum PhotoPhase {
  AVANT
  PENDANT
  APRES
}

// ---------------------------------------------------------------------------
// Platform users (authentication)
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  role         UserRole
  defaultValidatorUserId String? @db.Uuid
  status       AccountStatus @default(ACTIVE)
  inviteToken  String?  @unique
  inviteTokenExpiresAt DateTime?
  invitedAt    DateTime?
  acceptedAt   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  defaultValidator  User?      @relation("UserDefaultValidator", fields: [defaultValidatorUserId], references: [id], onDelete: SetNull)
  assignedUsers     User[]     @relation("UserDefaultValidator")
  uploadedDocuments  Document[] @relation("DocumentUploadedByUser")
  validatedDocuments Document[] @relation("DocumentValidatedByUser")
  uploadedPhotos     Photo[]    @relation("PhotoUploadedByUser")
  validatedPhotos    Photo[]    @relation("PhotoValidatedByUser")
  projectAssignments ProjectUserAssignment[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([defaultValidatorUserId])
}

// ---------------------------------------------------------------------------
// Materials & project container
// ---------------------------------------------------------------------------

model Material {
  id             String       @id @default(uuid()) @db.Uuid
  code           String       @unique
  name           String
  type           MaterialType
  origin         String?      @map("provenance")
  compatibility  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  elements  Element[]
  labTests  LabTest[]
}

model Actor {
  id             String     @id @default(uuid()) @db.Uuid
  code           String     @unique
  name           String
  organization   String?
  role           ActorRole
  email          String?
  phone          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  observationsAsAuthor Observation[]   @relation("ObservationAuthorActor")
  interventionsAsCompany Intervention[] @relation("InterventionCompanyActor")
  labTestsAsLaboratory LabTest[]       @relation("LabTestLaboratoryActor")
  documentsAsAuthor    Document[]      @relation("DocumentAuthorActor")
  photosAsAuthor       Photo[]         @relation("PhotoAuthorActor")
  logbooksAsAuthor     Logbook[]       @relation("LogbookAuthorActor")
  projectAssignments   ProjectActorAssignment[]
}

model Project {
  id              String        @id @default(uuid()) @db.Uuid
  code            String        @unique
  name            String
  location        String
  startDate       DateTime
  plannedEndDate  DateTime?
  status          ProjectStatus @default(PLANNED)
  imageUrl        String?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  zones     Zone[]
  logbooks  Logbook[]
  documents Document[]
  photos    Photo[]
  risks     Risk[]
  userAssignments  ProjectUserAssignment[]
  actorAssignments ProjectActorAssignment[]

  @@index([status])
}

model ProjectUserAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectActorAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  actorId   String   @db.Uuid
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   Actor   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([projectId, actorId])
  @@index([projectId])
  @@index([actorId])
}

// ---------------------------------------------------------------------------
// Zone pivot & elements
// ---------------------------------------------------------------------------

model Zone {
  id                   String               @id @default(uuid()) @db.Uuid
  projectId            String               @db.Uuid
  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code                 String
  name                 String
  /** Couverture zone → Cloudinary `rg3cp/{projectCode}/zones/{zoneCode}/cover`. */
  imageUrl             String?
  description          String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  elements         Element[]
  observations     Observation[]
  pathologies      Pathology[]
  decisions        Decision[]
  interventions    Intervention[]
  labTests         LabTest[]
  documents        Document[] @relation("DocumentPrimaryZone")
  relatedDocuments Document[] @relation("DocumentRelatedZone")
  photos           Photo[]    @relation("PhotoPrimaryZone")
  relatedPhotos    Photo[]    @relation("PhotoRelatedZone")
  risks            Risk[]

  @@unique([projectId, code])
  @@index([projectId])
}

model Element {
  id          String      @id @default(uuid()) @db.Uuid
  zoneId      String      @db.Uuid
  zone        Zone        @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  materialId  String?     @db.Uuid
  /** Matériau catalogue : pas de suppression en cascade du matériau. */
  material    Material?   @relation(fields: [materialId], references: [id], onDelete: SetNull)
  code        String
  name        String
  elementType ElementType
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  observations  Observation[]
  pathologies   Pathology[]
  interventions Intervention[]
  photos        Photo[]

  @@unique([zoneId, code])
  @@index([zoneId])
  @@index([materialId])
}

// ---------------------------------------------------------------------------
// Traceability chain
// ---------------------------------------------------------------------------

model Observation {
  id              String          @id @default(uuid()) @db.Uuid
  zoneId          String          @db.Uuid
  zone            Zone            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  elementId       String?         @db.Uuid
  /** Suppression de l’élément : les observations rattachées à cet élément sont supprimées. */
  element         Element?        @relation(fields: [elementId], references: [id], onDelete: Cascade)
  authorActorId   String?         @db.Uuid
  authorActor     Actor?          @relation("ObservationAuthorActor", fields: [authorActorId], references: [id], onDelete: SetNull)
  authorName      String?
  code            String
  title           String
  observationType ObservationType
  severity        SeverityLevel?
  description     String?         @db.Text
  observedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  pathologies     Pathology[]
  documents       Document[]
  photos          Photo[]
  decisions       Decision[]

  @@unique([zoneId, code])
  @@index([zoneId])
  @@index([elementId])
  @@index([authorActorId])
  @@index([observedAt])
}

model Pathology {
  id             String        @id @default(uuid()) @db.Uuid
  zoneId         String        @db.Uuid
  zone           Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  elementId      String?       @db.Uuid
  element        Element?      @relation(fields: [elementId], references: [id], onDelete: SetNull)
  observationId  String?       @db.Uuid
  /** Suppression de l’observation : pathologies liées supprimées en cascade. */
  observation    Observation?  @relation(fields: [observationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  pathologyType  PathologyType
  severity       SeverityLevel?
  description    String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  documents      Document[]
  photos         Photo[]
  decisions      Decision[]
  interventions  Intervention[]

  @@unique([zoneId, code])
  @@index([zoneId])
  @@index([elementId])
  @@index([observationId])
}

model Decision {
  id                  String         @id @default(uuid()) @db.Uuid
  zoneId              String         @db.Uuid
  zone                Zone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  observationId       String?        @db.Uuid
  /** Suppression de l’observation : décisions rattachées à cette observation supprimées. */
  observation         Observation?   @relation(fields: [observationId], references: [id], onDelete: Cascade)
  pathologyId         String?        @db.Uuid
  /** Suppression de la pathologie : la décision est conservée, lien optionnel mis à null. */
  pathology           Pathology?     @relation(fields: [pathologyId], references: [id], onDelete: SetNull)
  authorName          String?
  pvDocumentId        String?        @unique @db.Uuid
  pvDocument          Document?      @relation("DecisionPvDocument", fields: [pvDocumentId], references: [id], onDelete: SetNull)
  code                String
  title               String
  decisionType        DecisionType
  status              DecisionStatus @default(DRAFT)
  description         String?        @db.Text
  justification       String?        @db.Text
  doctrinalPrinciples String?        @db.Text
  decidedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  documents           Document[]          @relation("DecisionDocuments")
  interventions       Intervention[]
  risks               Risk[]
  logbookDecisions    LogbookDecision[]

  @@unique([zoneId, code])
  @@index([zoneId])
  @@index([observationId])
  @@index([pathologyId])
  @@index([decidedAt])
}

model Intervention {
  id               String             @id @default(uuid()) @db.Uuid
  decisionId       String             @db.Uuid
  decision         Decision           @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  zoneId           String             @db.Uuid
  zone             Zone               @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  elementId        String?            @db.Uuid
  element          Element?           @relation(fields: [elementId], references: [id], onDelete: SetNull)
  pathologyId      String?            @db.Uuid
  pathology        Pathology?         @relation(fields: [pathologyId], references: [id], onDelete: SetNull)
  companyActorId   String?            @db.Uuid
  companyActor     Actor?             @relation("InterventionCompanyActor", fields: [companyActorId], references: [id], onDelete: SetNull)
  companyName      String?
  code             String
  interventionType InterventionType
  status           InterventionStatus @default(PLANNED)
  description      String?            @db.Text
  /** Date métier de l’événement chantier (distinct des dates techniques / planning). */
  eventDate        DateTime?
  plannedStart     DateTime?
  plannedEnd       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  documents            Document[]
  photos               Photo[]
  risks                Risk[]
  logbookInterventions LogbookIntervention[]

  @@unique([decisionId, code])
  @@index([zoneId])
  @@index([decisionId])
  @@index([elementId])
  @@index([pathologyId])
  @@index([companyActorId])
  @@index([eventDate])
}

// ---------------------------------------------------------------------------
// Logbook
// ---------------------------------------------------------------------------

model Logbook {
  id                 String               @id @default(uuid()) @db.Uuid
  projectId          String               @db.Uuid
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code               String
  title              String
  description        String?              @db.Text
  authorActorId      String?              @db.Uuid
  authorActor        Actor?               @relation("LogbookAuthorActor", fields: [authorActorId], references: [id], onDelete: SetNull)
  authorName         String?
  weather            WeatherType?
  workforce          Int?
  eventAt            DateTime
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  documents          Document[]
  photos             Photo[]
  decisionLinks      LogbookDecision[]
  interventionLinks  LogbookIntervention[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([eventAt])
  @@index([authorActorId])
}

model LogbookDecision {
  id         String   @id @default(uuid()) @db.Uuid
  logbookId  String   @db.Uuid
  logbook    Logbook  @relation(fields: [logbookId], references: [id], onDelete: Cascade)
  decisionId String   @db.Uuid
  decision   Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([logbookId, decisionId])
  @@index([decisionId])
}

model LogbookIntervention {
  id             String       @id @default(uuid()) @db.Uuid
  logbookId      String       @db.Uuid
  logbook        Logbook      @relation(fields: [logbookId], references: [id], onDelete: Cascade)
  interventionId String       @db.Uuid
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([logbookId, interventionId])
  @@index([interventionId])
}

// ---------------------------------------------------------------------------
// Lab tests
// ---------------------------------------------------------------------------

model LabTest {
  id                String         @id @default(uuid()) @db.Uuid
  zoneId            String         @db.Uuid
  zone              Zone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  materialId        String?        @db.Uuid
  material          Material?      @relation(fields: [materialId], references: [id], onDelete: SetNull)
  laboratoryActorId String?        @db.Uuid
  laboratoryActor   Actor?         @relation("LabTestLaboratoryActor", fields: [laboratoryActorId], references: [id], onDelete: SetNull)
  laboratoryName    String?
  documentId        String?        @db.Uuid
  reportDocument    Document?      @relation("LabTestReport", fields: [documentId], references: [id], onDelete: SetNull)
  code              String
  labTestType       LabTestType
  result            LabTestResult?
  testedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([zoneId, code])
  @@index([zoneId])
  @@index([materialId])
  @@index([laboratoryActorId])
}

// ---------------------------------------------------------------------------
// Documentary evidence
// ---------------------------------------------------------------------------

model Document {
  id                String        @id @default(uuid()) @db.Uuid
  fileKind          FileKind
  originalFilename  String
  mimeType          String
  url               String
  secureUrl         String
  publicId          String
  assetFolder       String
  bytes             Int?
  format            String?
  title             String?
  category          String        @default("BDD_ADMIN")
  subCategory       String?
  bddCategory       String?
  tableName         String?
  subFolder         String?
  folderPath        String?
  status            ReviewStatus  @default(PENDING)
  scope             UploadScope   @default(PROJECT)
  storageType       StorageType   @default(CLOUDINARY)

  projectId         String?       @db.Uuid
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zoneId            String?       @db.Uuid
  zone              Zone?         @relation("DocumentPrimaryZone", fields: [zoneId], references: [id], onDelete: Cascade)
  observationId     String?       @db.Uuid
  observation       Observation?  @relation(fields: [observationId], references: [id], onDelete: Cascade)
  pathologyId       String?       @db.Uuid
  pathology         Pathology?    @relation(fields: [pathologyId], references: [id], onDelete: Cascade)
  decisionId        String?       @db.Uuid
  decision          Decision?     @relation("DecisionDocuments", fields: [decisionId], references: [id], onDelete: Cascade)
  interventionId    String?       @db.Uuid
  intervention      Intervention? @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  logbookId         String?       @db.Uuid
  logbook           Logbook?      @relation(fields: [logbookId], references: [id], onDelete: Cascade)
  authorActorId     String?       @db.Uuid
  authorActor       Actor?        @relation("DocumentAuthorActor", fields: [authorActorId], references: [id], onDelete: SetNull)

  authorName        String?
  uploadedById      String?       @db.Uuid
  uploadedBy        User?         @relation("DocumentUploadedByUser", fields: [uploadedById], references: [id], onDelete: SetNull)
  validatedById     String?       @db.Uuid
  validatedBy       User?         @relation("DocumentValidatedByUser", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt       DateTime?
  remarks           String?       @db.Text
  relatedZoneId     String?       @db.Uuid
  relatedZone       Zone?         @relation("DocumentRelatedZone", fields: [relatedZoneId], references: [id], onDelete: SetNull)

  /** Date métier du document (scan, PV, etc.) — distincte de la date d’upload. */
  documentDate      DateTime?

  pvForDecision     Decision?     @relation("DecisionPvDocument")
  labTests          LabTest[]     @relation("LabTestReport")

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([projectId])
  @@index([zoneId])
  @@index([observationId])
  @@index([pathologyId])
  @@index([decisionId])
  @@index([interventionId])
  @@index([logbookId])
  @@index([authorActorId])
  @@index([publicId])
  @@index([documentDate])
  @@index([status])
  @@index([category])
  @@index([bddCategory])
  @@index([tableName])
  @@index([subFolder])
  @@index([folderPath])
  @@index([relatedZoneId])
  @@index([validatedAt])
  @@index([uploadedById])
  @@index([validatedById])
}

model Photo {
  id               String        @id @default(uuid()) @db.Uuid
  fileKind         FileKind      @default(PHOTO)
  originalFilename String
  mimeType         String
  url              String
  secureUrl        String
  publicId         String
  assetFolder      String
  bytes            Int?
  format           String?
  title            String?
  caption          String?
  photoType        String?
  photoPhase       PhotoPhase?
  category         String        @default("BDD_MEDIA")
  subCategory      String?
  bddCategory      String?
  tableName        String?
  subFolder        String?
  folderPath       String?
  status           ReviewStatus  @default(PENDING)
  scope            UploadScope   @default(PROJECT)
  storageType      StorageType   @default(CLOUDINARY)

  projectId        String?       @db.Uuid
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zoneId           String?       @db.Uuid
  zone             Zone?         @relation("PhotoPrimaryZone", fields: [zoneId], references: [id], onDelete: Cascade)
  elementId        String?       @db.Uuid
  /** Suppression de l’élément : médias rattachés directement à l’élément supprimés. */
  element          Element?      @relation(fields: [elementId], references: [id], onDelete: Cascade)
  observationId    String?       @db.Uuid
  observation      Observation?  @relation(fields: [observationId], references: [id], onDelete: Cascade)
  pathologyId      String?       @db.Uuid
  pathology        Pathology?    @relation(fields: [pathologyId], references: [id], onDelete: Cascade)
  interventionId   String?       @db.Uuid
  intervention     Intervention? @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  logbookId        String?       @db.Uuid
  logbook          Logbook?      @relation(fields: [logbookId], references: [id], onDelete: Cascade)
  authorActorId    String?       @db.Uuid
  authorActor      Actor?        @relation("PhotoAuthorActor", fields: [authorActorId], references: [id], onDelete: SetNull)

  authorName       String?
  uploadedById     String?       @db.Uuid
  uploadedBy       User?         @relation("PhotoUploadedByUser", fields: [uploadedById], references: [id], onDelete: SetNull)
  validatedById    String?       @db.Uuid
  validatedBy      User?         @relation("PhotoValidatedByUser", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt      DateTime?
  remarks          String?       @db.Text
  relatedZoneId    String?       @db.Uuid
  relatedZone      Zone?         @relation("PhotoRelatedZone", fields: [relatedZoneId], references: [id], onDelete: SetNull)

  /** Date réelle de prise de vue (EXIF ou saisie) — distincte de la date d’upload. */
  takenAt          DateTime?
  dateFolder       String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([projectId])
  @@index([zoneId])
  @@index([elementId])
  @@index([observationId])
  @@index([pathologyId])
  @@index([interventionId])
  @@index([logbookId])
  @@index([authorActorId])
  @@index([publicId])
  @@index([takenAt])
  @@index([dateFolder])
  @@index([status])
  @@index([category])
  @@index([bddCategory])
  @@index([tableName])
  @@index([subFolder])
  @@index([folderPath])
  @@index([relatedZoneId])
  @@index([validatedAt])
  @@index([uploadedById])
  @@index([validatedById])
}

// ---------------------------------------------------------------------------
// Risk
// ---------------------------------------------------------------------------

model Risk {
  id             String           @id @default(uuid()) @db.Uuid
  code           String?          @unique
  title          String
  description    String?          @db.Text
  riskCategory   RiskCategory
  probability    RiskProbability?
  impact         RiskImpact?
  status         RiskStatus       @default(OPEN)
  mitigation     String?          @db.Text

  projectId      String?          @db.Uuid
  project        Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zoneId         String?          @db.Uuid
  zone           Zone?            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  decisionId     String?          @db.Uuid
  decision       Decision?        @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  interventionId String?          @db.Uuid
  intervention   Intervention?    @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  ownerName      String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([projectId])
  @@index([zoneId])
  @@index([decisionId])
  @@index([interventionId])
  @@index([status])
}